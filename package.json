  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint ./src",
    "format": "bunx prettier . --write",
    "format:check": "bunx prettier . --check",
    "type:check": "tsc --noEmit",
    "test": "bun test tests/**/*.test.ts",
    "clean": "rimraf dist",
    "prebuild": "bun run clean",
